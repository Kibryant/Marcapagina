{
  "name": "marcapagina-monorepo",
  "packageManager": "npm@11.5.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "web:dev": "turbo dev --filter=@marcapagina/web",
    "mobile:dev": "npm run start -w apps/mobile",
    "shared:build": "turbo build --filter=@marcapagina/shared"
  },
  "devDependencies": {
    "@turbo/gen": "^2.8.14",
    "turbo": "latest"
  }
}
