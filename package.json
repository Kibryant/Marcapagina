{
  "name": "marcapagina-monorepo",
  "packageManager": "npm@11.5.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "web:dev": "turbo dev --filter=@marcapagina/web",
    "mobile:dev": "turbo dev --filter=@marcapagina/mobile",
    "shared:build": "turbo build --filter=@marcapagina/shared"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@turbo/gen": "^2.8.14",
    "turbo": "latest"
  }
}
